	cd /home/ilm/Documents/GitHub/Altirra/build && $(MAKE) $(MAKESILENT) -f src/ATCore/CMakeFiles/ATCore.dir/build.make src/ATCore/CMakeFiles/ATCore.dir/source/vfs.cpp.s
.PHONY : source/vfs.cpp.s

